---
import { getSiteData, type Locale } from '../i18n';

interface Props { lang: Locale }
const { lang } = Astro.props;
const data = getSiteData(lang);
const { footer, profile, socials, nav } = data;
const whatsappUrl = `https://wa.me/${profile.phone.replace(/\D/g, '')}`;

const abbr: Record<string, string> = {
  GitHub: 'GH',
  Behance: 'Bē',
  LinkedIn: 'in',
  Dribbble: 'Dr',
};

/* Brand marks (simple-icons paths, 24×24 viewBox) — fallback = abbr text */
const iconPaths: Record<string, string> = {
