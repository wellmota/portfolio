  LinkedIn:
    'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z',
  Behance:
    'M16.969 16.927a2.561 2.561 0 0 0 1.901.677 2.501 2.501 0 0 0 1.531-.475c.362-.235.636-.584.779-.99h2.585a5.091 5.091 0 0 1-1.9 2.896 5.292 5.292 0 0 1-3.091.88 5.839 5.839 0 0 1-2.284-.433 4.871 4.871 0 0 1-1.723-1.211 5.657 5.657 0 0 1-1.08-1.874 7.057 7.057 0 0 1-.383-2.393c-.005-.8.129-1.595.396-2.349a5.313 5.313 0 0 1 5.088-3.604 4.87 4.87 0 0 1 2.376.563c.661.362 1.231.87 1.668 1.485a6.2 6.2 0 0 1 .943 2.133c.194.821.263 1.666.205 2.508h-7.699c-.063.79.184 1.574.688 2.187ZM6.947 4.084a8.065 8.065 0 0 1 1.928.198 4.29 4.29 0 0 1 1.49.638c.418.303.748.711.958 1.182.241.579.357 1.203.341 1.83a3.506 3.506 0 0 1-.506 1.961 3.726 3.726 0 0 1-1.503 1.287 3.588 3.588 0 0 1 2.027 1.437c.464.747.697 1.615.67 2.494a4.593 4.593 0 0 1-.423 2.032 3.945 3.945 0 0 1-1.163 1.413 5.114 5.114 0 0 1-1.683.807 7.135 7.135 0 0 1-1.928.259H0V4.084h6.947Zm-.235 12.9c.308.004.616-.029.916-.099a2.18 2.18 0 0 0 .766-.332c.228-.158.411-.371.534-.619.142-.317.208-.663.191-1.009a2.08 2.08 0 0 0-.642-1.715 2.618 2.618 0 0 0-1.696-.505h-3.54v4.279h3.471Zm13.635-5.967a2.13 2.13 0 0 0-1.654-.619 2.336 2.336 0 0 0-1.163.259 2.474 2.474 0 0 0-.738.62 2.359 2.359 0 0 0-.396.792c-.074.239-.12.485-.137.734h4.769a3.239 3.239 0 0 0-.679-1.785l-.002-.001Zm-13.813-.648a2.254 2.254 0 0 0 1.423-.433c.399-.355.607-.88.56-1.413a1.916 1.916 0 0 0-.178-.891 1.298 1.298 0 0 0-.495-.533 1.851 1.851 0 0 0-.711-.274 3.966 3.966 0 0 0-.835-.073H3.241v3.631h3.293v-.014ZM21.62 5.122h-5.976v1.527h5.976V5.122Z',
};
---

<footer class="border-t border-line bg-ink-soft">
  <div class="container-page py-12 sm:py-16 md:py-20">
    <div class="grid gap-10 sm:gap-12 md:grid-cols-12">
      <!-- Location + rotating seal -->
      <div class="md:col-span-4">
        <span class="label">Localização</span>
        <p class="mt-4 text-lg leading-snug text-cream">
          {profile.location}<br />
          <span class="text-mist">Aberto a trabalho remoto</span>
        </p>

        <!-- Rotating seal -->
        <div class="relative mt-10 h-28 w-28 sm:mt-14 sm:h-40 sm:w-40">
          <svg
            viewBox="0 0 200 200"
            class="spin-slow h-full w-full text-mist"
            aria-hidden="true"
          >
            <defs>
              <path
                id="sealPath"
                d="M100,100 m-74,0 a74,74 0 1,1 148,0 a74,74 0 1,1 -148,0"
                fill="none"></path>
            </defs>
            <text
              class="mono"
              font-size="10.5"
              letter-spacing="2.5"
              fill="currentColor"
            >
              <textPath href="#sealPath" startOffset="0"
                >{footer.badgeText}{footer.badgeText}</textPath
              >
            </text>
          </svg>
          <svg
            viewBox="0 0 200 200"
            class="absolute inset-0 h-full w-full"
            aria-hidden="true"
          >
            <text
              x="100"
              y="101"
              text-anchor="middle"
              dominant-baseline="central"
              style="font-family:'UnifrakturCook',serif;font-size:70px"
              fill="var(--color-cream)"
              >{profile.firstName.charAt(0)}</text
            >
          </svg>
        </div>
      </div>

      <!-- Inquiry + Links -->
      <div class="md:col-span-3">
        <span class="label">Contato</span>
        <a
          href={`mailto:${profile.email}`}
          class="link-underline mono mt-4 block text-[15px] text-cream"
          >{profile.email}</a
        >
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noreferrer"
          class="link-underline mono mt-2 block w-fit text-[15px] text-mist"
          >WhatsApp</a
        >

        <span class="label mt-12 block">Navegação</span>
        <ul class="mt-4 space-y-2.5">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-[15px] text-mist transition-colors hover:text-cream"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Brand + socials + newsletter -->
      <div class="md:col-span-5 md:pl-6">
        <div class="flex items-center gap-2.5">
          <span
            class="gothic grid h-8 w-8 place-items-center bg-lime pb-0.5 text-[19px] text-ink"
            >{profile.firstName.charAt(0)}</span
          >
          <span class="text-[15px] font-semibold tracking-tight"
            >{profile.name}</span
          >
        </div>
        <p class="mt-5 max-w-sm text-[15px] leading-relaxed text-mist">
          {footer.mission}
        </p>

        <!-- Socials -->
        <div class="mt-7 flex items-center gap-2.5">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noreferrer"
                aria-label={s.label}
                class="mono grid h-11 w-11 place-items-center rounded-full border border-line text-[12px] text-mist transition-colors hover:border-cream hover:text-cream"
              >
                {iconPaths[s.label] ? (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={iconPaths[s.label]} />
                  </svg>
                ) : (
                  abbr[s.label] ?? s.label.slice(0, 2)
                )}
              </a>
            ))
          }
        </div>

        <!-- Newsletter -->
        <form
          action={`mailto:${profile.email}`}
          method="post"
          enctype="text/plain"
          class="mt-10 max-w-md"
        >
          <span class="label">Vamos conversar</span>
          <div class="mt-4 flex items-center border border-line focus-within:border-line-strong">
            <input
              type="email"
              name="email"
              required
              placeholder="seu@email.com"
              class="w-full bg-transparent px-4 py-3.5 text-[14px] text-cream outline-none placeholder:text-faint"
            />
            <button
              type="submit"
              aria-label="Enviar"
              class="grid h-[3.25rem] w-14 shrink-0 place-items-center bg-cream text-ink transition-colors hover:bg-lime"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path
                  d="M3 8h10M9 4l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mono mt-16 flex flex-col items-start justify-between gap-4 border-t border-line pt-8 text-[12px] text-faint md:flex-row md:items-center"
    >
      <p>{footer.legal}</p>
      <p class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 bg-lime"></span>
        {profile.location}
      </p>
    </div>
  </div>
</footer>
