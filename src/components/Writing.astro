---
import { articles } from '../data/site';
import SectionHeader from './SectionHeader.astro';
---

<section id="escrita" class="container-page py-14 sm:py-20 md:py-32">
  <SectionHeader
    index="06"
    label="Escrita"
    title="Ideias sobre"
    titleMuted="design + código."
    caption="Artigos que publiquei sobre a interseção entre UX, front-end e processo de produto."
  />

  <div class="mt-16 border-t border-line" data-reveal>
    {
      articles.map((a, i) => (
        <a
          href={a.href}
          target="_blank"
          rel="noreferrer"
          class="group grid grid-cols-1 gap-4 border-b border-line py-8 transition-colors hover:bg-ink-soft md:grid-cols-12 md:items-baseline md:gap-8 md:px-4"
        >
          <span class="mono text-xs text-faint md:col-span-1">
            {String(i + 1).padStart(2, '0')}
          </span>

          <div class="md:col-span-7">
            <h3 class="display text-2xl leading-tight transition-colors group-hover:text-cream md:text-3xl">
              {a.title}
            </h3>
            <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-mist">
              {a.excerpt}
            </p>
          </div>

          <div class="mono flex flex-wrap gap-x-4 gap-y-1 text-[11px] uppercase tracking-widest text-faint md:col-span-3">
            <span>{a.date}</span>
            <span>{a.source}</span>
            <span class="text-mist">{a.tag}</span>
          </div>

          <div class="flex md:col-span-1 md:justify-end">
            <span class="grid h-10 w-10 place-items-center border border-line text-mist transition-colors group-hover:border-line-strong group-hover:text-cream">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <path
                  d="M4 12L12 4M12 4H5M12 4V11"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </div>
        </a>
      ))
    }
  </div>

  <div class="mt-8">
    <a
      href="https://medium.com/@wellingtonmota"
      target="_blank"
      rel="noreferrer"
      class="mono link-underline text-[13px] text-mist transition-colors hover:text-cream"
    >
      Ver todos no Medium →
    </a>
  </div>
</section>
