---
import { profile, heroStats, socials } from '../data/site';
const [first, ...rest] = profile.name.split(' ');
const last = rest.join(' ');
---

<section
  id="home"
  class="relative flex min-h-svh flex-col justify-end overflow-hidden pb-10 pt-32"
>
  <!-- Crosshair markers -->
  <span class="crosshair absolute left-[var(--gutter)] top-28 opacity-60"></span>
  <span class="crosshair absolute right-[var(--gutter)] top-28 opacity-60"></span>
  <span
    class="crosshair absolute left-1/2 top-1/2 hidden -translate-x-1/2 opacity-40 md:block"
  ></span>

  <div class="container-page relative flex flex-1 flex-col justify-between">
    <!-- Top meta row -->
    <div class="flex items-start justify-between gap-4 pt-6">
      <span class="label label-dot">
        {profile.availableText}
      </span>
      <span class="label hidden text-right leading-relaxed sm:block">
        Portfólio — Ed. 2026<br />
        <span class="text-mist">{profile.role}</span>
      </span>
    </div>

    <!-- Giant wordmark -->
    <h1 class="display mt-10 select-none">
      <span class="block overflow-hidden">
        <span
          class="hero-rise block text-[clamp(3.5rem,15vw,15rem)]"
          style="--reveal-delay:120ms">{first}</span
        >
      </span>
      <span class="block overflow-hidden">
        <span
          class="hero-rise block text-[clamp(3.5rem,15vw,15rem)] text-mist"
          style="--reveal-delay:260ms">{last}</span
        >
      </span>
    </h1>

    <!-- Bottom editorial band -->
    <div class="mt-14 border-t border-line pt-8">
      <div class="grid grid-cols-1 gap-x-8 gap-y-10 md:grid-cols-12">
        <!-- Stat -->
        <div class="md:col-span-3" data-reveal>
          <p class="display text-5xl">{heroStats.headline}</p>
          <p class="mt-2 max-w-[14ch] text-sm text-mist">
            {heroStats.label}
          </p>
        </div>

        <!-- Statement -->
        <div class="md:col-span-5 md:border-l md:border-line md:pl-8" data-reveal>
          <p class="text-lg leading-relaxed text-cream md:text-xl">
            {profile.tagline}
          </p>
          <p class="mt-2 text-sm text-faint">{heroStats.sub}</p>
        </div>

        <!-- Socials -->
        <div
          class="flex flex-col gap-2 md:col-span-2 md:border-l md:border-line md:pl-8"
          data-reveal
        >
          <span class="label mb-1">Redes</span>
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noreferrer"
                class="mono link-underline w-fit text-[13px] text-mist transition-colors hover:text-cream"
              >
                {s.label}
              </a>
            ))
          }
        </div>

        <!-- CTA -->
        <div
          class="flex flex-col items-start justify-end gap-3 md:col-span-2"
          data-reveal
        >
          <a href="#projetos" class="btn btn-solid w-full justify-between sm:w-auto">
            Ver experiência
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
              <path
                d="M4 12L12 4M12 4H5M12 4V11"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <a href="#contato" class="btn btn-outline w-full justify-between sm:w-auto">
            Fale comigo
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
              <path
                d="M4 12L12 4M12 4H5M12 4V11"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
