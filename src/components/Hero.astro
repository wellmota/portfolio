---
import { profile, heroStats, socials } from '../data/site';
const [first, ...rest] = profile.name.split(' ');
const last = rest.join(' ');
---

<section
  id="home"
  class="relative flex min-h-svh flex-col justify-end overflow-hidden pb-10 pt-32"
>
  <!-- Crosshair markers -->
  <span class="crosshair absolute left-[var(--gutter)] top-28 opacity-60"></span>
  <span class="crosshair absolute right-[var(--gutter)] top-28 opacity-60"></span>
  <span
    class="crosshair absolute left-1/2 top-1/2 hidden -translate-x-1/2 opacity-40 md:block"
  ></span>

  <div class="container-page relative flex flex-1 flex-col justify-between">
    <!-- Top meta row -->
    <div class="flex items-start justify-between gap-4 pt-6">
      <span class="label label-dot">
        {profile.availableText}
      </span>
    </div>

    <!-- Giant wordmark -->
    <h1 class="display mt-10 select-none">
      <span class="block">
        <span
          class="hero-rise block text-[clamp(3.5rem,15vw,15rem)]"
          style="--reveal-delay:120ms">{first}</span
        >
      </span>
      <span class="block">
        <span
          class="hero-rise block text-[clamp(3.5rem,15vw,15rem)] text-mist"
          style="--reveal-delay:260ms">{last}</span
        >
      </span>
    </h1>

    <!-- AI Specialist seal — editorial oversized, overlaps the wordmark -->
    <div
      class="pointer-events-none absolute right-[4%] top-[58%] z-20 hidden -translate-y-1/2 flex-row-reverse items-center gap-6 sm:flex sm:right-[5%] sm:top-[66%] md:right-[6%]"
      data-reveal
    >
      <div class="ai-seal-lg">
        <svg viewBox="0 0 120 120" fill="none" role="img" aria-label="Design Engineering · AI Specialist">
          <defs>
            <path
              id="ai-seal-path"
              d="M60,60 m-44,0 a44,44 0 1,1 88,0 a44,44 0 1,1 -88,0"
            ></path>
            <linearGradient
              id="ai-seal-grad"
              gradientUnits="userSpaceOnUse"
              x1="14"
              y1="14"
              x2="106"
              y2="106"
            >
              <stop offset="0" stop-color="var(--color-ai-1)"></stop>
              <stop offset="0.5" stop-color="var(--color-ai-2)"></stop>
              <stop offset="1" stop-color="var(--color-ai-3)"></stop>
            </linearGradient>
          </defs>

          <circle cx="60" cy="60" r="56" stroke="var(--color-line-strong)" stroke-width="1"></circle>

          <g class="ai-seal-rotate">
            <text class="ai-seal-text" fill="url(#ai-seal-grad)">
              <textPath
                href="#ai-seal-path"
                startOffset="0"
                textLength="276"
                lengthAdjust="spacingAndGlyphs"
              >
                DESIGN ENGINEERING · AI SPECIALIST ·
              </textPath>
            </text>
          </g>

          <!-- center gothic monogram (outline) -->
          <text
            x="60"
            y="61"
            text-anchor="middle"
            dominant-baseline="central"
            style="font-family:'UnifrakturCook',serif;font-size:46px"
            fill="none"
            stroke="url(#ai-seal-grad)"
            stroke-width="0.9"
            stroke-linejoin="round"
          >{profile.firstName.charAt(0)}</text>
        </svg>
      </div>
      <div class="label pointer-events-auto whitespace-nowrap text-right leading-loose">
        Portfólio — Ed. 2026<br />
        <span class="text-mist">{profile.role}</span><br />
        <span class="ai-text font-semibold">{profile.roleAi}</span>
      </div>
    </div>

    <!-- Mobile AI tag (below wordmark) -->
    <div class="mt-6 flex items-center gap-3 sm:hidden" data-reveal>
      <div class="ai-seal" style="width:3.5rem;height:3.5rem">
        <svg viewBox="0 0 120 120" fill="none" role="img" aria-label="AI Specialist">
          <defs>
            <path id="ai-seal-path-m" d="M60,60 m-44,0 a44,44 0 1,1 88,0 a44,44 0 1,1 -88,0"></path>
            <linearGradient id="ai-seal-grad-m" gradientUnits="userSpaceOnUse" x1="14" y1="14" x2="106" y2="106">
              <stop offset="0" stop-color="var(--color-ai-1)"></stop>
              <stop offset="0.5" stop-color="var(--color-ai-2)"></stop>
              <stop offset="1" stop-color="var(--color-ai-3)"></stop>
            </linearGradient>
          </defs>
          <circle cx="60" cy="60" r="56" stroke="var(--color-line-strong)" stroke-width="1"></circle>
          <g class="ai-seal-rotate">
            <text class="ai-seal-text" fill="url(#ai-seal-grad-m)">
              <textPath href="#ai-seal-path-m" startOffset="0" textLength="276" lengthAdjust="spacingAndGlyphs">DESIGN ENGINEERING · AI SPECIALIST ·</textPath>
            </text>
          </g>
          <text x="60" y="61" text-anchor="middle" dominant-baseline="central" style="font-family:'UnifrakturCook',serif;font-size:46px" fill="none" stroke="url(#ai-seal-grad-m)" stroke-width="0.9" stroke-linejoin="round">{profile.firstName.charAt(0)}</text>
        </svg>
      </div>
      <div class="label leading-loose">
        <span class="text-mist">{profile.role}</span><br />
        <span class="ai-text font-semibold">{profile.roleAi}</span>
      </div>
    </div>

    <!-- Bottom editorial band -->
    <div class="mt-10 border-t border-line pt-6 sm:mt-14 sm:pt-8">
      <div class="grid grid-cols-1 gap-x-8 gap-y-8 sm:gap-y-10 md:grid-cols-12">
        <!-- Stat -->
        <div class="md:col-span-3" data-reveal>
          <p class="display text-5xl">{heroStats.headline}</p>
          <p class="mt-2 max-w-[14ch] text-sm text-mist">
            {heroStats.label}
          </p>
        </div>

        <!-- Statement -->
        <div class="md:col-span-5 md:border-l md:border-line md:pl-8" data-reveal>
          <p class="text-lg leading-relaxed text-cream md:text-xl">
            {profile.tagline}
          </p>
          <p class="mt-2 text-sm text-faint">{heroStats.sub}</p>
        </div>

        <!-- Socials -->
        <div
          class="flex flex-col gap-2 md:col-span-2 md:border-l md:border-line md:pl-8"
          data-reveal
        >
          <span class="label mb-1">Redes</span>
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noreferrer"
                class="mono link-underline w-fit text-[13px] text-mist transition-colors hover:text-cream"
              >
                {s.label}
              </a>
            ))
          }
        </div>

        <!-- CTA -->
        <div
          class="flex flex-col items-start justify-end gap-3 md:col-span-2"
          data-reveal
        >
          <a href="#projetos" class="btn btn-solid w-full justify-between sm:w-auto">
            Ver experiência
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
              <path
                d="M4 12L12 4M12 4H5M12 4V11"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <a href="#contato" class="btn btn-outline w-full justify-between sm:w-auto">
            Fale comigo
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
              <path
                d="M4 12L12 4M12 4H5M12 4V11"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
