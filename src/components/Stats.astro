---
import { stats } from '../data/site';
---

<section class="container-page py-20 md:py-28">
  <div class="grid grid-cols-2 border-t border-line md:grid-cols-4">
    {
      stats.map((stat, i) => (
        <div
          class="border-b border-line px-1 py-8 md:border-b-0 md:border-l md:px-8 md:py-10 md:first:border-l-0"
          data-reveal
          data-reveal-group
        >
          <span class="mono text-[11px] text-faint">0{i + 1}</span>
          <p class="display mt-6 text-5xl md:text-6xl">{stat.value}</p>
          <p class="mt-3 text-sm text-mist">{stat.label}</p>
        </div>
      ))
    }
  </div>
</section>
