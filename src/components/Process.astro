---
import { getSiteData, type Locale } from '../i18n';
import SectionHeader from './SectionHeader.astro';

interface Props { lang: Locale }
const { lang } = Astro.props;
const data = getSiteData(lang);
const { process } = data;

const icons = [
  'M6 14a5 5 0 1 0 6-8M4 20l4-4', // discovery / pen-ish
  'M3 3h18v14H3zM8 21h8M12 17v4', // design / screen
  'M8 6l-5 6 5 6M16 6l5 6-5 6', // code
  'M4 12l5 5L20 6', // check / delivery
];
const offsets = ['lg:mt-0', 'lg:mt-14', 'lg:mt-28', 'lg:mt-40'];
---

<section class="border-y border-line bg-ink-soft py-14 sm:py-20 md:py-32">
  <div class="container-page">
    <SectionHeader
      index={data.ui.sectionProcess.index}
      label={data.ui.sectionProcess.label}
      title={data.ui.sectionProcess.title}
      titleMuted={data.ui.sectionProcess.titleMuted}
      caption={data.ui.sectionProcess.caption}
    />

    <div class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-4 lg:gap-4">
      {
        process.map((step, i) => (
          <article
            class:list={[
              'flex flex-col justify-between border border-line bg-surface p-5 transition-colors duration-300 hover:border-line-strong sm:min-h-[20rem] sm:p-7',
              offsets[i],
            ]}
            data-reveal
            data-reveal-group
          >
            <div class="flex items-start justify-between">
              <span class="grid h-12 w-12 place-items-center border border-line text-mist">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path
                    d={icons[i]}
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <span class="mono text-xs text-faint">{step.step}</span>
            </div>

            <div class="mt-10">
              <h3 class="display text-2xl">{step.title}</h3>
              <p class="mt-3 text-[14px] leading-relaxed text-mist">
                {step.description}
              </p>
              {step.ai && (
                <div class="mt-4 flex items-start gap-2.5 border-t border-line pt-4">
                  <span class="ai-text mono mt-px shrink-0 text-[10px] font-semibold">AI</span>
                  <p class="text-[13px] leading-snug text-mist">{step.ai}</p>
                </div>
              )}
            </div>

            <div class="mt-8">
              <div class="h-px w-full bg-line">
                <div
                  class="h-px bg-lime"
                  style={`width:${step.progress}%`}
                />
              </div>
              <div class="mono mt-3 flex items-center justify-between text-[11px] uppercase tracking-widest text-faint">
                <span>{step.title}</span>
                <span class="text-mist">{step.progress}%</span>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
