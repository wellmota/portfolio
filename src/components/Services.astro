---
import { services } from '../data/site';
import SectionHeader from './SectionHeader.astro';

const icons: Record<string, string> = {
  ux: 'M4 20l4-1 9.5-9.5a2.1 2.1 0 00-3-3L5 16l-1 4z',
  system: 'M4 4h7v7H4zM13 4h7v7h-7zM4 13h7v7H4zM13 13h7v7h-7z',
  code: 'M8 6l-5 6 5 6M16 6l5 6-5 6',
  ai: 'M12 2l1.9 5.1L19 9l-5.1 1.9L12 16l-1.9-5.1L5 9l5.1-1.9zM19 15l.8 2.2L22 18l-2.2.8L19 21l-.8-2.2L16 18l2.2-.8z',
  spark: 'M13 2L4 14h6l-1 8 10-12h-6z',
};
---

<section id="servicos" class="container-page py-20 md:py-32">
  <SectionHeader
    index="02"
    label="Especialidades"
    title="Do conceito ao"
    titleMuted="produto, ponta a ponta."
    caption="Um profissional só para desenhar e construir sua experiência digital, sem handoff."
  />

  <div class="mt-16 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <article
            class="flex min-h-[24rem] flex-col justify-between border border-line bg-ink-soft p-8 transition-colors hover:border-line-strong"
          >
            <div class="flex items-start justify-between">
              <span class="grid h-12 w-12 place-items-center border border-line text-cream">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                  <path
                    d={icons[s.icon]}
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <span class="mono text-xs text-faint">{s.index}</span>
            </div>

            <div class="mt-8 flex-1">
              <h3 class="display text-2xl leading-tight">{s.title}</h3>
              <ul class="mt-6 space-y-3">
                {s.points.map((p) => (
                  <li class="flex items-start gap-3 text-[14px] text-mist">
                    <span class="mono mt-0.5 shrink-0 text-lime">→</span>
                    {p}
                  </li>
                ))}
              </ul>
            </div>

            <div class="mono mt-8 flex items-center justify-between border-t border-line pt-5 text-[11px] uppercase tracking-widest">
              <span class="text-mist">{s.metaLeft}</span>
              <span class="text-cream">{s.badge}</span>
            </div>
          </article>
        ))
      }
  </div>
</section>
