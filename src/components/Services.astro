---
import { services } from '../data/site';
import SectionHeader from './SectionHeader.astro';

const icons: Record<string, string> = {
  ux: 'M4 20l4-1 9.5-9.5a2.1 2.1 0 00-3-3L5 16l-1 4z',
  system: 'M4 4h7v7H4zM13 4h7v7h-7zM4 13h7v7H4zM13 13h7v7h-7z',
  code: 'M8 6l-5 6 5 6M16 6l5 6-5 6',
  ai: 'M12 2l1.9 5.1L19 9l-5.1 1.9L12 16l-1.9-5.1L5 9l5.1-1.9zM19 15l.8 2.2L22 18l-2.2.8L19 21l-.8-2.2L16 18l2.2-.8z',
  spark: 'M13 2L4 14h6l-1 8 10-12h-6z',
};
---

<section id="servicos" class="container-page py-20 md:py-32">
  <SectionHeader
    index="02"
    label="Especialidades"
    title="Do conceito ao"
    titleMuted="código — em produção."
    caption="Um profissional só para desenhar e construir sua experiência digital, sem handoff."
  />

  <div class="mt-16" data-carousel>
    <!-- Track -->
    <div class="carousel" data-track>
      {
        services.map((s) => (
          <article
            data-card
            class="carousel-card flex min-h-[24rem] w-[85%] shrink-0 flex-col justify-between border border-line bg-ink-soft p-8 sm:w-[52%] lg:w-[31.6%]"
          >
            <div class="flex items-start justify-between">
              <span class="grid h-12 w-12 place-items-center border border-line text-cream">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                  <path
                    d={icons[s.icon]}
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <span class="mono text-xs text-faint">{s.index}</span>
            </div>

            <div class="mt-8 flex-1">
              <h3 class="display text-2xl leading-tight">{s.title}</h3>
              <ul class="mt-6 space-y-3">
                {s.points.map((p) => (
                  <li class="flex items-start gap-3 text-[14px] text-mist">
                    <span class="mono mt-0.5 shrink-0 text-lime">→</span>
                    {p}
                  </li>
                ))}
              </ul>
            </div>

            <div class="mono mt-8 flex items-center justify-between border-t border-line pt-5 text-[11px] uppercase tracking-widest">
              <span class="text-mist">{s.metaLeft}</span>
              <span class="text-cream">{s.badge}</span>
            </div>
          </article>
        ))
      }
    </div>

    <!-- Controls -->
    <div class="mt-8 flex items-center justify-between">
      <div class="flex items-center gap-2">
        {services.map((_, i) => (
          <button
            data-dot
            aria-label={`Ir para card ${i + 1}`}
            class:list={['carousel-dot', i === 0 && 'is-active']}
          />
        ))}
      </div>

      <div class="flex items-center gap-2">
        <button
          data-prev
          aria-label="Anterior"
          class="grid h-11 w-11 place-items-center border border-line text-mist transition-colors hover:border-line-strong hover:text-cream"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <button
          data-next
          aria-label="Próximo"
          class="grid h-11 w-11 place-items-center border border-line text-mist transition-colors hover:border-line-strong hover:text-cream"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-carousel]').forEach((root) => {
    const track = root.querySelector('[data-track]') as HTMLElement;
    const cards = [...root.querySelectorAll('[data-card]')] as HTMLElement[];
    const dots = [...root.querySelectorAll('[data-dot]')] as HTMLElement[];
    const prev = root.querySelector('[data-prev]');
    const next = root.querySelector('[data-next]');
    if (!track || !cards.length) return;

    const update = () => {
      const center = track.scrollLeft + track.clientWidth / 2;
      let best = 0,
        bestDist = Infinity;
      cards.forEach((c, i) => {
        const cc = c.offsetLeft + c.offsetWidth / 2;
        const d = Math.abs(cc - center);
        if (d < bestDist) {
          bestDist = d;
          best = i;
        }
      });
      cards.forEach((c, i) => c.classList.toggle('is-active', i === best));
      dots.forEach((d, i) => d.classList.toggle('is-active', i === best));
    };

    const goTo = (i: number) => {
      const c = cards[i];
      if (!c) return;
      track.scrollTo({
        left: c.offsetLeft - (track.clientWidth - c.offsetWidth) / 2,
        behavior: 'smooth',
      });
    };
    const current = () => dots.findIndex((d) => d.classList.contains('is-active'));

    track.addEventListener('scroll', () => requestAnimationFrame(update), {
      passive: true,
    });
    dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
    prev?.addEventListener('click', () => goTo(Math.max(0, current() - 1)));
    next?.addEventListener('click', () =>
      goTo(Math.min(cards.length - 1, current() + 1))
    );
    update();
  });
</script>
