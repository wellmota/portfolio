<script>
  // GA4 — eventos de conversão da página do livro
  (function () {
    const w = window as any;
    const track = (name: string, params?: Record<string, unknown>) => {
      if (typeof w.trackEvent === 'function') w.trackEvent(name, params || {});
    };
    const trackFB = (name: string, params?: Record<string, unknown>) => {
      if (typeof w.trackFB === 'function') w.trackFB(name, params || {});
    };
    const on = (sel: string, handler: () => void) => {
      document
        .querySelectorAll(sel)
        .forEach((el) => el.addEventListener('click', handler));
    };

    // Clique em qualquer botão "Comprar" → GA begin_checkout + Meta InitiateCheckout (R$37)
    on('a[href*="pay.kiwify"]', () => {
      track('begin_checkout', {
        currency: 'BRL',
        value: 37,
        items: [
          { item_name: 'Do Design ao Digital', price: 37, quantity: 1 },
        ],
      });
      trackFB('InitiateCheckout', { currency: 'BRL', value: 37 });
    });

    // Download da amostra grátis → GA + Meta Lead (+ captura de e-mail opcional)
    const fireLeadEvents = () => {
      track('amostra_download', {
        file_name: 'amostra-do-design-ao-digital.pdf',
      });
      trackFB('Lead', { content_name: 'amostra Do Design ao Digital' });
    };

    const gate = document.getElementById('lead-gate');
    const gEndpoint = gate ? gate.getAttribute('data-endpoint') || '' : '';

    if (gate && gEndpoint) {
      const gSample = gate.getAttribute('data-sample') || '/';
      const gFName = gate.getAttribute('data-fname') || 'name';
      const gFEmail = gate.getAttribute('data-femail') || 'email';
      const form = gate.querySelector('form') as HTMLFormElement | null;
      const status = gate.querySelector('[data-role="status"]');
      let sending = false;

      const openGate = () => {
        gate.hidden = false;
        document.body.style.overflow = 'hidden';
        const first = gate.querySelector('input') as HTMLInputElement | null;
        if (first) first.focus();
      };
      const closeGate = () => {
        gate.hidden = true;
        document.body.style.overflow = '';
      };

      document.querySelectorAll('a[href*="amostra"]').forEach((el) => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          openGate();
        });
      });
      gate.querySelectorAll('[data-close]').forEach((el) =>
        el.addEventListener('click', closeGate)
      );
      document.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Escape' && !gate.hidden) closeGate();
      });

      if (form) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          if (sending) return;
          const nameEl = form.querySelector('input[name="name"]') as HTMLInputElement | null;
          const emailEl = form.querySelector('input[name="email"]') as HTMLInputElement | null;
          const nameVal = ((nameEl && nameEl.value) || '').trim();
          const emailVal = ((emailEl && emailEl.value) || '').trim();
          if (!emailVal || !/.+@.+\..+/.test(emailVal)) {
            if (emailEl) emailEl.focus();
            if (status) status.textContent = 'Digite um e-mail válido.';
            return;
          }
          sending = true;
          if (status) status.textContent = 'Enviando...';
          const params = new URLSearchParams();
          params.set(gFEmail, emailVal);
          if (nameVal) params.set(gFName, nameVal);
          params.set('ml-submit', '1');
          params.set('anticsrf', 'true');
          const done = () => {
            fireLeadEvents();
            if (status) status.textContent = 'Pronto! Abrindo a amostra...';
            window.open(gSample, '_blank', 'noopener');
            setTimeout(closeGate, 900);
            sending = false;
          };
          fetch(gEndpoint, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params.toString(),
          })
            .then(done)
            .catch(done);
        });
      }
    } else {
      // Sem captura configurada: download direto (comportamento atual)
      on('a[href*="amostra"]', fireLeadEvents);
    }

    // Clique no WhatsApp
    on('a[href*="wa.me"]', () => track('whatsapp_click', {}));
  })();
</script>

