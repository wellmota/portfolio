---
import '../styles/global.css';
import { getSiteData, type Locale, defaultLocale } from '../i18n';

interface Props {
  lang?: Locale;
  title?: string;
  description?: string;
}

const lang = Astro.props.lang ?? defaultLocale;
const data = getSiteData(lang);
const htmlLang = lang === 'pt' ? 'pt-BR' : 'en';

const {
  title = `${data.profile.name} — ${data.profile.role}`,
  description = data.profile.tagline,
} = Astro.props;

const siteUrl = 'https://userexperience.com.br';
const canonicalUrl = lang === 'pt' ? `${siteUrl}/pt/` : `${siteUrl}/`;
const ogImage = `${siteUrl}/og-image.jpg`;

const jsonLdPerson = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Wellington Mota',
  url: siteUrl,
  image: ogImage,
  email: 'mailto:wellingtonmota42@gmail.com',
  telephone: '+55-61-98104-3296',
  jobTitle: 'Product Engineer',
  description: 'Product Engineer with 15+ years in digital product design and 3+ years shipping front-end in modern stacks. Specializes in closing the gap between design and code.',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Brasília',
    addressCountry: 'BR',
  },
  knowsAbout: [
    'React', 'Next.js', 'TypeScript', 'Node.js', 'Tailwind CSS',
    'Design Systems', 'UX Research', 'UI Design', 'Figma',
    'AI Engineering', 'Agent Orchestration', 'MCP', 'Prompt Engineering',
    'RAG', 'LLM Evals', 'REST API', 'GraphQL',
    'Front-end Development', 'Product Design', 'Accessibility', 'WCAG',
  ],
  knowsLanguage: ['en', 'pt-BR'],
  sameAs: [
    'https://github.com/wellmota',
    'https://www.linkedin.com/in/wellingtonmota13/',
    'https://www.behance.net/wellingtonmota',
    'https://medium.com/@wellingtonmota',
  ],
};

const jsonLdWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: `${data.profile.name} — Portfolio`,
  url: siteUrl,
  inLanguage: ['en', 'pt-BR'],
  author: { '@type': 'Person', name: 'Wellington Mota' },
};

const jsonLdProfilePage = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: { '@id': siteUrl },
  name: title,
  url: canonicalUrl,
  inLanguage: htmlLang,
};
---

<!doctype html>
<html lang={htmlLang} data-tz={data.profile.timezone} data-locale={lang}>
  <head>
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Wellington Mota" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Wellington Mota — Portfolio" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={htmlLang === 'pt-BR' ? 'pt_BR' : 'en_US'} />
    {lang === 'en' && <meta property="og:locale:alternate" content="pt_BR" />}
    {lang === 'pt' && <meta property="og:locale:alternate" content="en_US" />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#08080a" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdPerson)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebSite)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdProfilePage)} />

    <!-- Alternate language -->
    <link rel="alternate" hreflang="en" href="https://userexperience.com.br/" />
    <link rel="alternate" hreflang="pt" href="https://userexperience.com.br/pt/" />
    <link rel="alternate" hreflang="x-default" href="https://userexperience.com.br/" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&family=UnifrakturCook:wght@700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script>
      const locale = document.documentElement.dataset.locale || 'en';
      const dateLocale = locale === 'pt' ? 'pt-BR' : 'en-US';

      // ---- Reveal on scroll --------------------------------------------
      const revealEls = document.querySelectorAll('[data-reveal], [data-reveal-line]');
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
      );
      revealEls.forEach((el, i) => {
        if (!el.getAttribute('style')?.includes('--reveal-delay')) {
          const group = el.getAttribute('data-reveal-group');
          if (group) el.style.setProperty('--reveal-delay', `${(i % 6) * 70}ms`);
        }
        io.observe(el);
      });

      // ---- Live clock (nav + footer) -----------------------------------
      const tz = document.documentElement.dataset.tz || 'America/Sao_Paulo';
      const clocks = document.querySelectorAll('[data-clock]');
      function tick() {
        const time = new Intl.DateTimeFormat(dateLocale, {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          timeZone: tz,
          hour12: false,
        }).format(new Date());
        clocks.forEach((c) => (c.textContent = time));
      }
      if (clocks.length) {
        tick();
        setInterval(tick, 1000);
      }

      // ---- Sticky nav shadow on scroll ---------------------------------
      const nav = document.querySelector('[data-nav]');
      if (nav) {
        const onScroll = () => {
          nav.classList.toggle('is-scrolled', window.scrollY > 24);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // ---- Mobile menu -------------------------------------------------
      const burger = document.querySelector('[data-burger]');
      const menu = document.querySelector('[data-mobile-menu]');
      if (burger && menu) {
        const toggle = (open: boolean) => {
          menu.classList.toggle('is-open', open);
          burger.classList.toggle('is-open', open);
          document.body.style.overflow = open ? 'hidden' : '';
        };
        burger.addEventListener('click', () =>
          toggle(!menu.classList.contains('is-open'))
        );
        menu.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', () => toggle(false))
        );
      }
    </script>
  </body>
</html>
