---
import '../styles/global.css';
import { getSiteData, type Locale, defaultLocale } from '../i18n';

interface Props {
  lang?: Locale;
  title?: string;
  description?: string;
  /** Caminho (relativo à raiz do site) de uma OG image específica da página */
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  /** hreflang EN/PT — só faz sentido nas homes */
  alternates?: boolean;
}

const lang = Astro.props.lang ?? defaultLocale;
const data = getSiteData(lang);
const htmlLang = lang === 'pt' ? 'pt-BR' : 'en';

const {
  title = `${data.profile.name} — ${data.profile.role}`,
  description = data.profile.tagline,
} = Astro.props;

/* ---------------- SEO ---------------- */
const siteUrl = 'https://userexperience.com.br';
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = `${siteUrl}${Astro.props.ogImage ?? '/og-image.png'}`;
const ogImageAlt =
  Astro.props.ogImageAlt ?? `${data.profile.name} — ${data.profile.role}`;
const ogImageWidth = Astro.props.ogImageWidth ?? 1200;
const ogImageHeight = Astro.props.ogImageHeight ?? 630;
const alternates = Astro.props.alternates ?? true;

const sameAs = data.socials
  .map((s) => s.href)
  .filter((h) => h && h !== '#' && h.startsWith('http'));

/* Structured data — ajuda Google/LLMs a entenderem quem é a pessoa */
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.profile.name,
  jobTitle: data.profile.role,
  description: data.profile.tagline,
  url: siteUrl,
  image: `${siteUrl}${data.about.image}`,
  email: `mailto:${data.profile.email}`,
  telephone: data.profile.phone,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Brasília',
    addressRegion: 'DF',
    addressCountry: 'BR',
  },
  sameAs,
  knowsAbout: [
    'Product Engineering',
    'Design Engineering',
    'Front-End Development',
    'React',
    'TypeScript',
    'Next.js',
    'Design Systems',
    'UX Research',
    'AI Engineering',
    'Agent Orchestration',
    'RAG',
    'Prompt Engineering',
    'LLM Evaluation',
  ],
};
---

<!doctype html>
<html lang={htmlLang} data-tz={data.profile.timezone} data-locale={lang}>
  <head>
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="author" content={data.profile.name} />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={htmlLang} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={data.profile.name} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#08080a" />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(personSchema)}
    />

    <!-- Alternate language -->
    {
      alternates && (
        <>
          <link rel="alternate" hreflang="en" href="https://userexperience.com.br/" />
          <link rel="alternate" hreflang="pt" href="https://userexperience.com.br/pt/" />
          <link rel="alternate" hreflang="x-default" href="https://userexperience.com.br/" />
        </>
      )
    }

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&family=UnifrakturCook:wght@700&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics 4 (gtag) + Consent Mode (LGPD) -->
    <!-- O GA só é carregado depois do consentimento; padrão = negado -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      window.gtag = gtag;

      // Consent Mode v2 — nada de armazenamento até o usuário aceitar
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500,
      });
      gtag('js', new Date());

      window.__GA_ID = 'G-N7HJ2X28SX';
      window.loadGA = function () {
        if (window.__gaLoaded) return;
        window.__gaLoaded = true;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + window.__GA_ID;
        document.head.appendChild(s);
        gtag('config', window.__GA_ID);
      };

      // Dispara eventos com segurança (no-op enquanto o GA não estiver carregado)
      window.trackEvent = function (name, params) {
        try { window.gtag('event', name, params || {}); } catch (e) {}
      };

      // Se já consentiu numa visita anterior, ativa e carrega agora
      try {
        if (localStorage.getItem('ux_consent') === 'granted') {
          gtag('consent', 'update', { analytics_storage: 'granted' });
          window.loadGA();
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <slot />

    <!-- Banner de consentimento (LGPD) -->
    <div id="cookie-consent" class="consent" hidden>
      <p class="consent__txt">
        Usamos cookies do Google Analytics apenas para entender o tráfego do site.
        Você escolhe.
      </p>
      <div class="consent__actions">
        <button type="button" data-consent="deny" class="consent__btn consent__btn--ghost">
          Recusar
        </button>
        <button type="button" data-consent="grant" class="consent__btn consent__btn--solid">
          Aceitar
        </button>
      </div>
    </div>

    <style>
      .consent {
        position: fixed;
        z-index: 120;
        left: 1rem;
        right: 1rem;
        bottom: 1rem;
        max-width: 640px;
        margin-inline: auto;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.85rem 1.25rem;
        padding: 1rem 1.15rem;
        background: #101010;
        border: 1px solid #232323;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
      }
      .consent__txt {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        line-height: 1.55;
        color: #b6b6bb;
        margin: 0;
        flex: 1 1 240px;
      }
      .consent__actions {
        display: flex;
        gap: 0.5rem;
        margin-left: auto;
      }
      .consent__btn {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        padding: 0.6rem 0.95rem;
        border: 1px solid #3a3a3a;
        background: transparent;
        color: #ededed;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
      }
      .consent__btn--ghost:hover {
        border-color: #ededed;
      }
      .consent__btn--solid {
        background: #cff24a;
        color: #0a0a0a;
        border-color: #cff24a;
        font-weight: 600;
      }
      .consent__btn--solid:hover {
        filter: brightness(1.05);
      }
    </style>

    <script>
      (function () {
        const el = document.getElementById('cookie-consent');
        if (!el) return;
        let choice = null;
        try {
          choice = localStorage.getItem('ux_consent');
        } catch (e) {}
        if (!choice) el.hidden = false;

        el.querySelectorAll('[data-consent]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const grant = btn.getAttribute('data-consent') === 'grant';
            try {
              localStorage.setItem('ux_consent', grant ? 'granted' : 'denied');
            } catch (e) {}
            const w = window as any;
            if (grant && typeof w.gtag === 'function') {
              w.gtag('consent', 'update', { analytics_storage: 'granted' });
              if (typeof w.loadGA === 'function') w.loadGA();
            }
            el.hidden = true;
          });
        });
      })();
    </script>

    <script>
      const locale = document.documentElement.dataset.locale || 'en';
      const dateLocale = locale === 'pt' ? 'pt-BR' : 'en-US';

      // ---- Reveal on scroll --------------------------------------------
      const revealEls = document.querySelectorAll('[data-reveal], [data-reveal-line]');
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
      );
      revealEls.forEach((el, i) => {
        if (!el.getAttribute('style')?.includes('--reveal-delay')) {
          const group = el.getAttribute('data-reveal-group');
          if (group) el.style.setProperty('--reveal-delay', `${(i % 6) * 70}ms`);
        }
        io.observe(el);
      });

      // ---- Live clock (nav + footer) -----------------------------------
      const tz = document.documentElement.dataset.tz || 'America/Sao_Paulo';
      const clocks = document.querySelectorAll('[data-clock]');
      function tick() {
        const time = new Intl.DateTimeFormat(dateLocale, {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          timeZone: tz,
          hour12: false,
        }).format(new Date());
        clocks.forEach((c) => (c.textContent = time));
      }
      if (clocks.length) {
        tick();
        setInterval(tick, 1000);
      }

      // ---- Sticky nav shadow on scroll ---------------------------------
      const nav = document.querySelector('[data-nav]');
      if (nav) {
        const onScroll = () => {
          nav.classList.toggle('is-scrolled', window.scrollY > 24);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // ---- Mobile menu -------------------------------------------------
      const burger = document.querySelector('[data-burger]');
      const menu = document.querySelector('[data-mobile-menu]');
      if (burger && menu) {
        const toggle = (open: boolean) => {
          menu.classList.toggle('is-open', open);
          burger.classList.toggle('is-open', open);
          document.body.style.overflow = open ? 'hidden' : '';
        };
        burger.addEventListener('click', () =>
          toggle(!menu.classList.contains('is-open'))
        );
        menu.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', () => toggle(false))
        );
      }
    </script>
  </body>
</html>
