---
import '../styles/global.css';
import { getSiteData, type Locale, defaultLocale } from '../i18n';

interface Props {
  lang?: Locale;
  title?: string;
  description?: string;
}

const lang = Astro.props.lang ?? defaultLocale;
const data = getSiteData(lang);
const htmlLang = lang === 'pt' ? 'pt-BR' : 'en';

const {
  title = `${data.profile.name} — ${data.profile.role}`,
  description = data.profile.tagline,
} = Astro.props;

/* ---------------- SEO ---------------- */
const siteUrl = 'https://userexperience.com.br';
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = `${siteUrl}/og-image.png`;

const sameAs = data.socials
  .map((s) => s.href)
  .filter((h) => h && h !== '#' && h.startsWith('http'));

/* Structured data — ajuda Google/LLMs a entenderem quem é a pessoa */
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.profile.name,
  jobTitle: data.profile.role,
  description: data.profile.tagline,
  url: siteUrl,
  image: `${siteUrl}${data.about.image}`,
  email: `mailto:${data.profile.email}`,
  telephone: data.profile.phone,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Brasília',
    addressRegion: 'DF',
    addressCountry: 'BR',
  },
  sameAs,
  knowsAbout: [
    'Product Engineering',
    'Design Engineering',
    'Front-End Development',
    'React',
    'TypeScript',
    'Next.js',
    'Design Systems',
    'UX Research',
    'AI Engineering',
    'Agent Orchestration',
    'RAG',
    'Prompt Engineering',
    'LLM Evaluation',
  ],
};
---

<!doctype html>
<html lang={htmlLang} data-tz={data.profile.timezone} data-locale={lang}>
  <head>
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="author" content={data.profile.name} />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={htmlLang} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={data.profile.name} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${data.profile.name} — ${data.profile.role}`} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#08080a" />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(personSchema)}
    />

    <!-- Alternate language -->
    <link rel="alternate" hreflang="en" href="https://userexperience.com.br/" />
    <link rel="alternate" hreflang="pt" href="https://userexperience.com.br/pt/" />
    <link rel="alternate" hreflang="x-default" href="https://userexperience.com.br/" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&family=UnifrakturCook:wght@700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script>
      const locale = document.documentElement.dataset.locale || 'en';
      const dateLocale = locale === 'pt' ? 'pt-BR' : 'en-US';

      // ---- Reveal on scroll --------------------------------------------
      const revealEls = document.querySelectorAll('[data-reveal], [data-reveal-line]');
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
      );
      revealEls.forEach((el, i) => {
        if (!el.getAttribute('style')?.includes('--reveal-delay')) {
          const group = el.getAttribute('data-reveal-group');
          if (group) el.style.setProperty('--reveal-delay', `${(i % 6) * 70}ms`);
        }
        io.observe(el);
      });

      // ---- Live clock (nav + footer) -----------------------------------
      const tz = document.documentElement.dataset.tz || 'America/Sao_Paulo';
      const clocks = document.querySelectorAll('[data-clock]');
      function tick() {
        const time = new Intl.DateTimeFormat(dateLocale, {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          timeZone: tz,
          hour12: false,
        }).format(new Date());
        clocks.forEach((c) => (c.textContent = time));
      }
      if (clocks.length) {
        tick();
        setInterval(tick, 1000);
      }

      // ---- Sticky nav shadow on scroll ---------------------------------
      const nav = document.querySelector('[data-nav]');
      if (nav) {
        const onScroll = () => {
          nav.classList.toggle('is-scrolled', window.scrollY > 24);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // ---- Mobile menu -------------------------------------------------
      const burger = document.querySelector('[data-burger]');
      const menu = document.querySelector('[data-mobile-menu]');
      if (burger && menu) {
        const toggle = (open: boolean) => {
          menu.classList.toggle('is-open', open);
          burger.classList.toggle('is-open', open);
          document.body.style.overflow = open ? 'hidden' : '';
        };
        burger.addEventListener('click', () =>
          toggle(!menu.classList.contains('is-open'))
        );
        menu.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', () => toggle(false))
        );
      }
    </script>
  </body>
</html>
